  const [logFilter, setLogFilter] = useState("all");

  const tabs = [
    { id: "dashboard", label: "Dashboard", icon: Flame },
    { id: "quickio", label: "Quick In/Out", icon: PlusCircle },
    { id: "manual", label: "Manual Record", icon: ClipboardList },
    { id: "log", label: "Inventory Log", icon: ClipboardList },
    { id: "stock", label: "Remain Stock", icon: Package },
    { id: "bottles", label: "ຂວດເປີດ", icon: Droplets },
    { id: "clock", label: "Clock In/Out", icon: Clock },
    { id: "manager", label: "Manager", icon: Shield },
  ];

  return (
    <div className="lao min-h-screen bg-app text-white">
      {FONT}
      <div className="max-w-5xl mx-auto px-5 py-6">
        <div className="mb-5 flex items-center justify-between flex-wrap gap-3">
          <div>
            <h1 className="lao text-xl font-bold bg-clip-text text-transparent grad-primary inline-block">LA DOLCE</h1>
            <p className="lao text-sm text-white/40">ລະບົບຄັງສິນຄ້າ · Inventory Dashboard</p>
          </div>
          <div className="flex items-center gap-2">
            {BRANCHES.length > 1 ? (
              <div className="flex items-center gap-1.5 glass rounded-xl px-3 py-2">
                <Building2 size={14} className="text-white/50" />
                <select value={branchId} onChange={(e) => setBranchId(e.target.value)} className="lao bg-transparent text-sm text-white outline-none">
                  {BRANCHES.map((b) => <option key={b.id} value={b.id} className="text-black">{b.name}</option>)}
                </select>
              </div>
            ) : (
              <div className="flex items-center gap-1.5 glass rounded-xl px-3 py-2 text-white/50 text-sm lao">
                <Building2 size={14} /> {branch.name}
              </div>
            )}
            <button onClick={reload} className="glass rounded-xl p-2.5 text-white/60 hover:text-white transition-colors">
              <RefreshCw size={16} className={loading ? "animate-spin" : ""} />
            </button>
          </div>
        </div>

        <div className="flex gap-1.5 overflow-x-auto pb-4 mb-2 -mx-1 px-1">
          {tabs.map((t) => (
            <TabButton key={t.id} active={tab === t.id} onClick={() => setTab(t.id)} icon={t.icon} label={t.label} />
          ))}
        </div>

        {error && <ErrorBanner message={error} onRetry={reload} />}
        {loading && !data && <Loading label="ກຳລັງໂຫລດຂໍ້ມູນ..." />}

        {data && (
          <div>
            {tab === "dashboard" && <Dashboard data={data} bottles={bottles} goLog={() => setTab("log")} setFilter={setLogFilter} />}
            {tab === "quickio" && <QuickInOut data={data} reload={reload} url={branch.url} />}
            {tab === "manual" && <ManualRecord data={data} reload={reload} url={branch.url} />}
            {tab === "log" && <InventoryLog data={data} filter={logFilter} setFilter={setLogFilter} />}
            {tab === "stock" && <RemainStock data={data} />}
            {tab === "bottles" && <OpenBottles bottles={bottles} reload={reload} url={branch.url} />}
            {tab === "clock" && <ClockInOut data={data} url={branch.url} />}
            {tab === "manager" && <ManagerPanel url={branch.url} reload={reload} />}
          </div>
        )}
      </div>
    </div>
  );
}
