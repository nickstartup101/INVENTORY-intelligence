// ---------- QUICK IN/OUT ----------
function QuickInOut({ data, reload, url }) {
  const inventory = data.inventory || [];
  const categories = useMemo(() => [...new Set(inventory.map((p) => p.CATEGORY).filter(Boolean))], [inventory]);
  const [cat, setCat] = useState(categories[0] || "");
  useEffect(() => { if (!cat && categories[0]) setCat(categories[0]); }, [categories]);
  const [qtys, setQtys] = useState({});
  const [submitting, setSubmitting] = useState(false);
  const [msg, setMsg] = useState("");
  const items = inventory.filter((p) => p.CATEGORY === cat);

  const setQty = (sku, delta) => setQtys((s) => ({ ...s, [sku]: Math.max(0, (s[sku] || 0) + delta) }));

  const submit = async () => {
    const toSend = Object.entries(qtys).filter(([, q]) => q > 0);
    if (toSend.length === 0) return;
    setSubmitting(true);
    setMsg("");
    try {
      for (const [sku, qty] of toSend) {
        const product = inventory.find((p) => p.SKU === sku);
        await apiPost(url, { action: "stockMove", item: product.NAME, type: "OUT", qty, remark: "Quick Out" });
      }
      setQtys({});
      setMsg("ບັນທຶກສຳເລັດ ✅");
      reload();
    } catch (e) {
      setMsg("ຜິດພາດ: " + e.message);
    } finally {
      setSubmitting(false);
    }
  };

  return (
    <div className="space-y-5">
      <div className="flex gap-2 overflow-x-auto pb-1">
        {categories.map((c) => (
          <button
            key={c}
            onClick={() => setCat(c)}
            className={`lao text-sm px-4 py-2 rounded-2xl font-medium whitespace-nowrap transition-all ${
              cat === c ? "grad-primary text-white" : "glass text-white/60"
            }`}
          >
            {c}
          </button>
        ))}
      </div>

      <div className="grid grid-cols-2 gap-3">
        {items.map((p) => (
          <GlassCard key={p.SKU} className="p-4">
            <div className="flex items-center justify-between">
              <span className="lao text-sm font-medium text-white">{p.NAME}</span>
              <span className="num text-xs text-white/40">{fmt(p["CURRENT STOCK"])}</span>
            </div>
            <div className="flex items-center justify-between mt-3">
              <button onClick={() => setQty(p.SKU, -1)} className="w-9 h-9 rounded-full bg-rose-400/15 text-rose-300 flex items-center justify-center active:scale-95 transition-transform">
                <MinusCircle size={20} />
              </button>
              <span className="num text-lg font-bold w-10 text-center text-white">{qtys[p.SKU] || 0}</span>
              <button onClick={() => setQty(p.SKU, 1)} className="w-9 h-9 rounded-full bg-emerald-400/15 text-emerald-300 flex items-center justify-center active:scale-95 transition-transform">
                <PlusCircle size={20} />
              </button>
            </div>
          </GlassCard>
        ))}
        {items.length === 0 && <div className="lao text-white/40 text-sm col-span-2 text-center py-8">ບໍ່ມີລາຍການໃນໝວດນີ້</div>}
      </div>

      <button onClick={submit} disabled={submitting} className="lao w-full grad-primary text-white rounded-2xl py-3 font-medium disabled:opacity-50">
        {submitting ? "ກຳລັງບັນທຶກ..." : "ບັນທຶກລາຍການອອກ (Out)"}
      </button>
      {msg && <div className="lao text-sm text-center text-white/70">{msg}</div>}
    </div>
  );
}

// ---------- MANUAL RECORD ----------
function ManualRecord({ data, reload, url }) {
  const inventory = data.inventory || [];
  const [item, setItem] = useState(inventory[0]?.NAME || "");
  const [type, setType] = useState("OUT");
  const [qty, setQty] = useState("");
  const [remark, setRemark] = useState("");
  const [submitting, setSubmitting] = useState(false);
  const [msg, setMsg] = useState("");

  const submit = async () => {
    if (!item || !qty) return;
    setSubmitting(true);
    setMsg("");
    try {
      const r = await apiPost(url, { action: "stockMove", item, type, qty: Number(qty), remark });
      if (r.error) throw new Error(r.error);
      setMsg("ບັນທຶກສຳເລັດ ✅");
      setQty(""); setRemark("");
      reload();
    } catch (e) {
      setMsg("ຜິດພາດ: " + e.message);
    } finally {
      setSubmitting(false);
    }
  };

  return (
    <GlassCard className="p-5 max-w-md">
      <h3 className="lao font-semibold mb-4 text-white">ບັນທຶກແບບ Manual (ເດີມ)</h3>
      <div className="space-y-3">
        <div>
          <label className="lao text-xs text-white/50">ລາຍການ</label>
          <select value={item} onChange={(e) => setItem(e.target.value)} className="lao w-full mt-1 bg-white/5 border border-white/15 rounded-xl px-3 py-2 text-sm text-white">
            {inventory.map((p) => <option key={p.SKU} value={p.NAME} className="text-black">{p.NAME}</option>)}
          </select>
        </div>
        <div className="flex gap-3">
          <div className="flex-1">
            <label className="lao text-xs text-white/50">ຈຳນວນ</label>
            <input type="number" value={qty} onChange={(e) => setQty(e.target.value)} className="num w-full mt-1 bg-white/5 border border-white/15 rounded-xl px-3 py-2 text-sm text-white" placeholder="0" />
          </div>
          <div className="flex-1">
            <label className="lao text-xs text-white/50">ປະເພດ</label>
            <div className="flex gap-2 mt-1">
              <button onClick={() => setType("IN")} className={`lao flex-1 rounded-xl py-2 text-sm font-medium ${type === "IN" ? "bg-emerald-500/80 text-white" : "bg-white/5 text-white/40"}`}>In (+)</button>
              <button onClick={() => setType("OUT")} className={`lao flex-1 rounded-xl py-2 text-sm font-medium ${type === "OUT" ? "bg-rose-500/80 text-white" : "bg-white/5 text-white/40"}`}>Out (-)</button>
            </div>
          </div>
        </div>
        <div>
          <label className="lao text-xs text-white/50">ໝາຍເຫດ</label>
          <textarea value={remark} onChange={(e) => setRemark(e.target.value)} className="lao w-full mt-1 bg-white/5 border border-white/15 rounded-xl px-3 py-2 text-sm text-white" rows={2} placeholder="ໝາຍເຫດ (ຖ້າມີ)" />
        </div>
        <button onClick={submit} disabled={submitting} className="lao w-full grad-primary text-white rounded-xl py-2.5 font-medium mt-2 disabled:opacity-50">
          {submitting ? "ກຳລັງບັນທຶກ..." : "ບັນທຶກ"}
        </button>
        {msg && <div className="lao text-xs text-center text-white/70">{msg}</div>}
      </div>
    </GlassCard>
  );
}

