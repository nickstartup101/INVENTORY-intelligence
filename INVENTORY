function OpenBottles({ bottles, reload, url }) {
  const [modal, setModal] = useState(null);
  const [remark, setRemark] = useState("");
  const [busy, setBusy] = useState(false);

  const doOpen = async (sku) => {
    setBusy(true);
    try {
      await apiPost(url, { action: "openNewBottle", sku, remark });
      setModal(null); setRemark("");
      reload();
    } finally { setBusy(false); }
  };

  return (
    <div className="space-y-3">
      {(bottles || []).map((b) => (
        <GlassCard key={b.sku} className="p-4 flex items-center justify-between">
          <div>
            <div className="lao font-medium text-sm text-white">{b.name}</div>
            <div className="lao text-xs text-white/40 mt-0.5">ຄົງເຫຼືອ <span className="num">{b.pctRemaining}%</span> · ໃຊ້ໄປ <span className="num">{fmt(b.mlUsed)}</span>/<span className="num">{fmt(b.bottleSize)}</span></div>
            {b.remark && <div className="lao text-xs text-rose-300 mt-1">{b.remark}</div>}
          </div>
          <button onClick={() => setModal(b.sku)} className="lao flex items-center gap-1.5 text-xs font-medium bg-white/10 hover:bg-white/15 rounded-xl px-3 py-2 text-white">
            <RotateCcw size={14} /> ເປີດຂວດໃໝ່
          </button>
        </GlassCard>
      ))}
      {(!bottles || bottles.length === 0) && <div className="lao text-white/40 text-sm text-center py-8">ຍັງບໍ່ໄດ້ຕັ້ງຄ່າແທັບ "ຂວດເປີດ"</div>}

      {modal && (
        <div className="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
          <GlassCard strong className="p-5 w-full max-w-sm">
            <div className="flex items-center justify-between mb-3">
              <h4 className="lao font-semibold text-white">ເປີດຂວດໃໝ່ ແລະ ໝາຍເຫດ</h4>
              <button onClick={() => setModal(null)}><X size={18} className="text-white/40" /></button>
            </div>
            <textarea value={remark} onChange={(e) => setRemark(e.target.value)} placeholder="ເຊັ່ນ: ຂວດເກົ່າບູດ/ເສຍ..." className="lao w-full bg-white/5 border border-white/15 rounded-xl px-3 py-2 text-sm mb-3 text-white" rows={3} />
            <button onClick={() => doOpen(modal)} disabled={busy} className="lao w-full grad-primary text-white rounded-xl py-2.5 font-medium disabled:opacity-50">
              {busy ? "ກຳລັງບັນທຶກ..." : "ຢືນຢັນ"}
            </button>
          </GlassCard>
        </div>
      )}
    </div>
  );
}

// ---------- CLOCK IN/OUT ----------
function ClockInOut({ data, url }) {
  const employees = data.employees || [];
  const [empId, setEmpId] = useState(employees[0]?.ID || "");
  const [pin, setPin] = useState("");
  const [stage, setStage] = useState(null);
  const [checked, setChecked] = useState({});
  const [msg, setMsg] = useState("");
  const [busy, setBusy] = useState(false);

  useEffect(() => { if (!empId && employees[0]) setEmpId(employees[0].ID); }, [employees]);

  const list = stage === "IN" ? (data.tasksIn || []) : (data.tasksOut || []);
  const allChecked = list.length > 0 && list.every((_, i) => checked[i]);

  const submit = async () => {
    setBusy(true); setMsg("");
    try {
      const action = stage === "IN" ? "clockIn" : "clockOut";
      const doneNames = list.filter((_, i) => checked[i]).map((t) => t["ຊື່ວຽກ"]);
      const r = await apiPost(url, { action, empId, pin, checklist: doneNames });
      if (r.error) throw new Error(r.error);
      if (r.warning) setMsg(r.warning);
      else setMsg(r.message + " (" + r.time + ")");
      setStage(null); setChecked({}); setPin("");
    } catch (e) {
      setMsg("ຜິດພາດ: " + e.message);
    } finally { setBusy(false); }
  };

  return (
    <div className="max-w-md space-y-4">
      <GlassCard className="p-5">
        <h3 className="lao font-semibold mb-4 text-white">ລົງເວລາເຮັດວຽກ</h3>
        <div className="space-y-3">
          <div>
            <label className="lao text-xs text-white/50">ພະນັກງານ</label>
            <select value={empId} onChange={(e) => setEmpId(e.target.value)} className="lao w-full mt-1 bg-white/5 border border-white/15 rounded-xl px-3 py-2 text-sm text-white">
              {employees.map((e) => <option key={e.ID} value={e.ID} className="text-black">{e["ຊື່"]} {e["ນາມສະກຸນ"]}</option>)}
            </select>
          </div>
          <div>
            <label className="lao text-xs text-white/50">PIN</label>
            <input type="password" value={pin} onChange={(e) => setPin(e.target.value)} className="num w-full mt-1 bg-white/5 border border-white/15 rounded-xl px-3 py-2 text-sm text-white" placeholder="••••••" />
          </div>
        </div>
        <div className="grid grid-cols-2 gap-3 mt-4">
          <button onClick={() => setStage("IN")} className="lao flex flex-col items-center gap-2 rounded-2xl py-5 border border-white/10 hover:bg-white/5 text-white">
            <LogIn size={20} /><span className="text-sm font-medium">ຕອກບັດເຂົ້າ</span>
          </button>
          <button onClick={() => setStage("OUT")} className="lao flex flex-col items-center gap-2 rounded-2xl py-5 border border-white/10 hover:bg-white/5 text-white">
            <LogOut size={20} /><span className="text-sm font-medium">ຕອກບັດອອກ</span>
          </button>
        </div>
        {msg && <div className="lao text-xs text-center text-white/70 mt-3">{msg}</div>}
      </GlassCard>

      {stage && (
        <GlassCard className="p-5">
          <div className="flex items-center gap-2 mb-4">
            <Clock size={16} className="text-white/50" />
            <h4 className="lao font-semibold text-sm text-white">{stage === "IN" ? "ລາຍການກວດ ຫຼັງເຂົ້າວຽກ" : "ລາຍການກວດ ກ່ອນອອກວຽກ"}</h4>
          </div>
          {list.length === 0 && <div className="lao text-white/40 text-sm py-4 text-center">ຍັງບໍ່ມີ Task ຈາກ Manager ສຳລັບຊ່ວງນີ້</div>}
          <div className="space-y-2">
            {list.map((task, i) => (
              <button
                key={task.TaskID || i}
                onClick={() => setChecked((c) => ({ ...c, [i]: !c[i] }))}
                className="lao flex items-center gap-3 text-sm w-full text-left rounded-xl px-3 py-2.5 transition-all"
                style={{
                  background: checked[i] ? `${task["ສີ"] || "#38BDF8"}22` : "rgba(255,255,255,0.04)",
                  borderLeft: `3px solid ${task["ສີ"] || "#38BDF8"}`,
                }}
              >
                {checked[i] ? <CheckCircle2 size={19} style={{ color: task["ສີ"] || "#38BDF8" }} className="shrink-0" /> : <Circle size={19} className="text-white/20 shrink-0" />}
                <span className={checked[i] ? "text-white/50 line-through" : "text-white"}>{task["ຊື່ວຽກ"]}</span>
              </button>
            ))}
          </div>
          <button onClick={submit} disabled={!allChecked || busy} className="lao w-full mt-5 rounded-xl py-2.5 font-medium disabled:bg-white/10 disabled:text-white/30 grad-primary text-white">
            {busy ? "ກຳລັງບັນທຶກ..." : "ຢືນຢັນສຳເລັດ ແລະ Submit"}
          </button>
        </GlassCard>
      )}
    </div>
  );
}

// ---------- MANAGER PANEL (PIN-gated task management) ----------
function ManagerPanel({ url, reload }) {
  const [authed, setAuthed] = useState(false);
  const [pin, setPin] = useState("");
  const [err, setErr] = useState("");
  const [tasksIn, setTasksIn] = useState([]);
  const [tasksOut, setTasksOut] = useState([]);
  const [name, setName] = useState("");
  const [shift, setShift] = useState("IN");
  const [color, setColor] = useState("#38BDF8");
  const [busy, setBusy] = useState(false);

  const COLORS = ["#38BDF8", "#5EEAD4", "#FF6B9D", "#C965DB", "#FBBF24", "#FF8A65"];

  const refreshTasks = useCallback(async () => {
    const [tin, tout] = await Promise.all([apiGet(url, "tasks", { shift: "IN" }), apiGet(url, "tasks", { shift: "OUT" })]);
    setTasksIn(Array.isArray(tin) ? tin : []);
    setTasksOut(Array.isArray(tout) ? tout : []);
  }, [url]);

  const login = async () => {
    setErr("");
    try {
      const r = await apiPost(url, { action: "managerAuth", pin });
      if (r.success) { setAuthed(true); refreshTasks(); }
      else setErr("PIN ບໍ່ຖືກຕ້ອງ");
    } catch (e) { setErr(e.message); }
  };

  const addTask = async () => {
    if (!name.trim()) return;
    setBusy(true);
    try {
      await apiPost(url, { action: "addTask", pin, name, shift, color });
      setName("");
      await refreshTasks();
      reload();
    } finally { setBusy(false); }
  };

  const removeTask = async (taskId) => {
    setBusy(true);
    try {
      await apiPost(url, { action: "deleteTask", pin, taskId });
      await refreshTasks();
      reload();
    } finally { setBusy(false); }
  };

  if (!authed) {
    return (
      <GlassCard className="p-6 max-w-xs mx-auto text-center">
        <Shield size={28} className="text-white/50 mx-auto mb-3" />
        <h3 className="lao font-semibold text-white mb-1">ເຂົ້າສູ່ລະບົບ Manager</h3>
        <p className="lao text-xs text-white/40 mb-4">ໃສ່ PIN ເພື່ອຈັດການ Task ປະຈຳວັນ</p>
        <input type="password" value={pin} onChange={(e) => setPin(e.target.value)} onKeyDown={(e) => e.key === "Enter" && login()}
          className="num w-full bg-white/5 border border-white/15 rounded-xl px-3 py-2 text-sm text-white text-center mb-3" placeholder="PIN" />
        <button onClick={login} className="lao w-full grad-primary text-white rounded-xl py-2.5 font-medium">ເຂົ້າສູ່ລະບົບ</button>
        {err && <div className="lao text-xs text-rose-300 mt-2">{err}</div>}
      </GlassCard>
    );
  }

  const TaskList = ({ list, title }) => (
    <GlassCard className="p-5">
      <h4 className="lao font-semibold text-sm text-white mb-3">{title}</h4>
      <div className="space-y-2">
        {list.map((t) => (
          <div key={t.TaskID} className="flex items-center justify-between rounded-xl px-3 py-2" style={{ background: `${t["ສີ"]}18`, borderLeft: `3px solid ${t["ສີ"]}` }}>
            <span className="lao text-sm text-white">{t["ຊື່ວຽກ"]}</span>
            <button onClick={() => removeTask(t.TaskID)} disabled={busy}><Trash2 size={15} className="text-white/40 hover:text-rose-300" /></button>
          </div>
        ))}
        {list.length === 0 && <div className="lao text-xs text-white/30 text-center py-3">ບໍ່ມີ Task</div>}
      </div>
    </GlassCard>
  );

  return (
    <div className="space-y-4 max-w-xl">
      <GlassCard className="p-5">
        <h3 className="lao font-semibold text-white mb-4 flex items-center gap-2"><Shield size={16} /> ຈັດການ Task ປະຈຳວັນ</h3>
        <div className="space-y-3">
          <input value={name} onChange={(e) => setName(e.target.value)} placeholder="ຊື່ Task ໃໝ່..." className="lao w-full bg-white/5 border border-white/15 rounded-xl px-3 py-2 text-sm text-white" />
          <div className="flex items-center gap-3">
            <div className="flex gap-2">
              <button onClick={() => setShift("IN")} className={`lao text-xs px-3 py-2 rounded-lg font-medium ${shift === "IN" ? "grad-primary text-white" : "bg-white/5 text-white/50"}`}>ເຂົ້າວຽກ</button>
              <button onClick={() => setShift("OUT")} className={`lao text-xs px-3 py-2 rounded-lg font-medium ${shift === "OUT" ? "grad-primary text-white" : "bg-white/5 text-white/50"}`}>ອອກວຽກ</button>
            </div>
            <div className="flex gap-1.5 ml-auto">
              {COLORS.map((c) => (
                <button key={c} onClick={() => setColor(c)} className="w-6 h-6 rounded-full transition-transform" style={{ background: c, transform: color === c ? "scale(1.25)" : "scale(1)", boxShadow: color === c ? `0 0 0 2px white` : "none" }} />
              ))}
            </div>
          </div>
          <button onClick={addTask} disabled={busy} className="lao w-full grad-primary text-white rounded-xl py-2.5 font-medium flex items-center justify-center gap-2 disabled:opacity-50">
            <Plus size={16} /> ເພີ່ມ Task
          </button>
        </div>
      </GlassCard>
      <TaskList list={tasksIn} title="Task ຫຼັງເຂົ້າວຽກ" />
      <TaskList list={tasksOut} title="Task ກ່ອນອອກວຽກ" />
    </div>
  );
}

