// ---------- APP DATA HOOK (branch-aware) ----------
function useAppData(baseUrl) {
  const [data, setData] = useState(null);
  const [bottles, setBottles] = useState(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);

  const load = useCallback(async () => {
    setLoading(true);
    setError(null);
    try {
      const [all, b] = await Promise.all([apiGet(baseUrl, "all"), apiGet(baseUrl, "bottles")]);
      if (all.error) throw new Error(all.error);
      setData(all);
      setBottles(Array.isArray(b) ? b : []);
    } catch (e) {
      setError(e.message || "ໂຫລດຂໍ້ມູນບໍ່ສຳເລັດ");
    } finally {
      setLoading(false);
    }
  }, [baseUrl]);

  useEffect(() => { load(); }, [load]);
  return { data, bottles, loading, error, reload: load };
}

// ---------- DASHBOARD ----------
function Dashboard({ data, bottles, goLog, setFilter }) {
  const log = data.log || [];
  const inventory = data.inventory || [];
  const totalIn = log.filter((l) => l.Type === "IN").length;
  const totalOut = log.filter((l) => l.Type === "OUT").length;

  // rough burn-rate: total OUT qty per item across the log window / distinct days seen
  const days = new Set(log.map((l) => String(l["TIME STAMP"]).slice(0, 10))).size || 1;
  const outByItem = {};
  log.forEach((l) => {
    if (l.Type === "OUT") outByItem[l.Item] = (outByItem[l.Item] || 0) + Number(l.Qty || 0);
  });
  const hotItems = Object.entries(outByItem)
    .map(([name, totalOutQty]) => {
      const perDay = totalOutQty / days;
      const product = inventory.find((p) => p.NAME === name);
      const stock = product ? Number(product["CURRENT STOCK"]) : null;
      const daysLeft = stock !== null && perDay > 0 ? Math.max(0, Math.floor(stock / perDay)) : null;
      return { name, perDay, stock, daysLeft, product };
    })
    .sort((a, b) => b.perDay - a.perDay)
    .slice(0, 4);

  return (
    <div className="space-y-5">
      <div className="grid grid-cols-2 gap-4">
        <GlassCard strong className="p-5 cursor-pointer hover:scale-[1.01] transition-transform" onClick={() => { setFilter("IN"); goLog(); }}>
          <div className="flex items-center justify-between">
            <div className="flex items-center gap-2 text-emerald-300">
              <ArrowDownRight size={18} />
              <span className="text-sm font-medium lao">ລາຍການເຂົ້າ (In)</span>
            </div>
            <ChevronRight size={16} className="text-white/30" />
          </div>
          <div className="num text-3xl font-bold mt-2 text-white">{totalIn}</div>
          <div className="text-xs text-white/40 lao mt-1">ຈາກ log ລ່າສຸດ · ກົດເບິ່ງລາຍລະອຽດ</div>
        </GlassCard>
        <GlassCard strong className="p-5 cursor-pointer hover:scale-[1.01] transition-transform" onClick={() => { setFilter("OUT"); goLog(); }}>
          <div className="flex items-center justify-between">
            <div className="flex items-center gap-2 text-rose-300">
              <ArrowUpRight size={18} />
              <span className="text-sm font-medium lao">ລາຍການອອກ (Out)</span>
            </div>
            <ChevronRight size={16} className="text-white/30" />
          </div>
          <div className="num text-3xl font-bold mt-2 text-white">{totalOut}</div>
          <div className="text-xs text-white/40 lao mt-1">ຈາກ log ລ່າສຸດ · ກົດເບິ່ງລາຍລະອຽດ</div>
        </GlassCard>
      </div>

      <GlassCard className="p-5">
        <div className="flex items-center gap-2 mb-4">
          <Flame size={18} className="text-orange-300" />
          <h3 className="lao font-semibold text-white">Hot Stock — ເຄື່ອງເຄື່ອນໄຫວອອກເລື້ອຍ</h3>
        </div>
        {hotItems.length === 0 && <div className="lao text-white/40 text-sm py-6 text-center">ຍັງບໍ່ມີຂໍ້ມູນພຽງພໍໃນ log</div>}
        <div className="grid grid-cols-2 gap-3">
          {hotItems.map((p) => {
            const dl = p.daysLeft;
            const color = dl === null ? "#8b8b95" : dl <= 2 ? "#FF5252" : dl <= 5 ? "#FBBF24" : "#5EEAD4";
            const ratio = p.product ? Math.min(100, (p.stock / Number(p.product["MIN_STOCK <"] || p.stock || 1)) * 100) : 0;
