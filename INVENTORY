// ---------- REMAIN STOCK ----------
function RemainStock({ data }) {
  const inventory = data.inventory || [];
  const categories = [...new Set(inventory.map((p) => p.CATEGORY).filter(Boolean))];
  return (
    <div className="space-y-5">
      {categories.map((c) => {
        const items = inventory.filter((p) => p.CATEGORY === c);
        return (
          <GlassCard key={c} className="p-5">
            <h3 className="lao font-semibold text-sm mb-3 text-white">{c}</h3>
            <div className="space-y-2.5">
              {items.map((p) => {
                const min = Number(p["MIN_STOCK <"] || 1);
                const cur = Number(p["CURRENT STOCK"] || 0);
                const ratio = Math.max(0, Math.min(100, (cur / (min * 3 || 1)) * 100));
                const low = cur <= min;
                return (
                  <div key={p.SKU}>
                    <div className="flex justify-between text-xs mb-1">
                      <span className="lao text-white/80">{p.NAME}</span>
                      <span className="num text-white/40">{fmt(cur)} (min {fmt(min)})</span>
                    </div>
                    <div className="h-2 rounded-full bg-white/10 overflow-hidden">
                      <div className={`h-full rounded-full ${low ? "grad-warn" : "grad-liquid"}`} style={{ width: `${ratio}%` }} />
                    </div>
                  </div>
                );
              })}
            </div>
          </GlassCard>
        );
      })}
    </div>
  );
}

